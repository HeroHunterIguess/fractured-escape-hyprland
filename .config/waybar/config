{
  "layer": "bot",
  "spacing": -2,
  "height": 18,
  "margin-bottom": 0,
  "margin-top": 0,
  "margin-left": 0,
  "margin-right": 0,
  "position": "top",
  "modules-left": ["hyprland/workspaces", "network", "custom/LOCKIN", "custom/loading", "custom/notification_script"],
  "modules-center": ["clock"],
  "modules-right": ["custom/weather", "pulseaudio", "cpu", "custom/gpu", "memory"],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "hyprctl dispatch workspace {name}"
  },

  "custom/notification_script": {
    "format": " {}",
    "exec": "~/Everything/scripts/toggle-notifications.sh",
    "interval": 1
  },

  "custom/applauncher": {
    "format": "o",
    "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun",
    "tooltip": true
  },

  "clock": {
    "format": "[ {:%I:%M %p | %m-%d-%Y ]}",
    "tooltip-format": "{:%A, %d %B %Y}",
    "interval": 60
  },

  "custom/weather": {
      "format": "[{}]",
      "exec": "~/Everything/scripts/weather.sh",
      "interval": 120,
      "tooltip": false
  },

  "cpu": {
    "format": "[CPU: {usage}%]"
  },

  "custom/gpu": {
    "exec": "cat /sys/class/hwmon/hwmon7/device/gpu_busy_percent",
    "format": "[GPU: {}%]",
    "return-type": "",
    "interval": 1
  },

  "custom/gpu_temp": {
    "exec": "sensors -u | grep -A 1 'junction:' | grep 'temp2_input' | awk '{print $2}' | cut -c1-2",
    "format": "[GPU: {}°C]",
    "interval": 1
  },

  "memory": {
    "format": "[RAM: {}%]"
  },

  "network": {
    "format": "{ifname}",
    "format-disconnected": "⚠ Disconnected",
    "format-wifi": "[ᯤ{signalStrength}%]"
  },

  "custom/RW": {
    "format": "[ᯤ⚠]",
    "on-click": "sudo /home/herohunter/Everything/scripts/driverscript.sh",
    "tooltip": true,
    "tooltip-format": "Reset wifi drivers"
  },

  "custom/LOCKIN": {
    "format": "[LOCK IN]",
    "on-click": "bash -c '/home/herohunter/Everything/scripts/togglelockin.sh'"
  },

  "pulseaudio": {
    "format": "[🕪{volume}%]",
    "format-muted": "MUTED"
  },

  "custom/loading": {
    "exec": "~/Everything/scripts/loading.sh",
    "format": "[{}]"
  },

  "custom/binary_counter": {
    "exec": "~/Everything/scripts/binary_counter.sh",
    "format": "{}"
  }
}
